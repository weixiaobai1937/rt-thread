menu "Hardware Drivers Config"

choice
    prompt "select chip type"
    default SOC_ACM32P40N128CCT

    config SOC_ACM32P40N128CCT
    bool "SOC_ACM32P40N128CCT"
    select RT_USING_COMPONENTS_INIT
    select RT_USING_USER_MAIN
    help
        ACM32P40N128CCT, Cortex-M33 core, 128KB SRAM, 1MB Flash

endchoice

menu "ACM32P4xx Chip Configuration"
    depends on SOC_ACM32P40N128CCT

    config SOC_SRAM_START_ADDR
        hex "sram start address"
        default 0x20000000

    config SOC_SRAM_SIZE
        hex "sram size(KBytes)"
        default 0x80

    config SOC_FLASH_START_ADDR
        hex "Flash Start Address"
        default 0x08000000

    config SOC_FLASH_SIZE
        hex "Flash Size(KBytes)"
        default 0x400

endmenu

menu "ACM32P4xx Onboard Peripheral Drivers"

    config BSP_USING_UART1
        bool "Enable UART1 (PA9/PA10)"
        select RT_USING_SERIAL_V2
        default y

    config BSP_USING_UART2
        bool "Enable UART2 (PD5/PD6)"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_UART3
        bool "Enable UART3 (PB10/PB11)"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_UART4
        bool "Enable UART4 (PC10/PC11)"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_UART5
        bool "Enable UART5"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_UART6
        bool "Enable UART6"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_UART7
        bool "Enable UART7"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_UART8
        bool "Enable UART8"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_LPUART1
        bool "Enable LPUART1 (PA2/PA3)"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_LPUART2
        bool "Enable LPUART2 (PB10/PB11)"
        select RT_USING_SERIAL_V2
        default n

    config BSP_USING_GPIO1
        bool "Enable GPIO1"
        select RT_USING_PIN
        default y

endmenu

endmenu
